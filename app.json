{
  "expo": {
    "name": "MAIZE_GUARD",
    "slug": "MAIZE_GUARD",
    "scheme": "maizeguard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B5E20"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maizeguard.app"
    },
    "android": {
      "package": "com.maizeguard.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "buildArchs": ["arm64-v8a"]
          }
        }
      ],
      "./app.plugin.js"
    ],
    "extra": {
      "eas": {
        "projectId": "96a0a892-7290-4c6f-af1d-6d5a0a4037e7"
      }
    }
  }
}
